{
  "name": "bond-sports-task",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test:watch": "vitest",
    "preview": "vite preview",
    "server": "node --import=tsx --watch-path=./src src/server/index.ts",
    "seed": "node --import=tsx src/db/seed.ts",
    "playground": "node --import=tsx --watch src/playground.example.ts",
    "drizzle:push": "drizzle-kit push",
    "drizzle:migrate:create": "drizzle-kit generate",
    "drizzle:migrate:apply": "drizzle-kit migrate"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.18.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@libsql/client": "^0.17.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "jiti": "^2.6.1",
    "pg": "^8.20.0",
    "postgres": "^3.4.8"
  }
}
